{
  "name": "node-rag-system",
  "version": "1.0.0",
  "description": "Scalable SaaS-ready RAG (Retrieval-Augmented Generation) platform built with Node.js, Express, TypeScript, LangChain, and vector databases, featuring secure APIs, JWT authentication, and production-grade architecture for AI-powered knowledge retrieval and chat applications.",
  "main": "server.js",
  "scripts": {
    "prepare": "husky install",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --exec ts-node src/server.ts",
    "build": "tsc",
    "build:prod": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "create_migration": "prisma migrate dev --create-only --name ",
    "update_database": "prisma migrate dev",
    "validate_schema": "prisma validate",
    "generate_prisma_client": "prisma generate",
    "lint": "prettier --check src/",
    "format": "prettier --write src/"
  },
  "author": "Sonu Sharma",
  "license": "ISC",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "inversify": "^7.11.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "stripe": "^20.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "husky": "^9.0.0",
    "jest": "^30.2.0",
    "jest-extended": "^7.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "prisma": "^7.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
