# Application
NODE_ENV=development
PORT=3001
APP_NAME=Node Express Prisma Starter REST API
APP_VERSION=1.0.0
APP_MODE=local

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/app

# JWT (minimum 32 characters for secrets)
JWT_SECRET=your-jwt-secret-min-32-characters
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-characters
JWT_REFRESH_EXPIRES_IN=7d
JWT_AUDIENCE=
JWT_ISSUER=

# Azure Blob Storage (optional)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=
AZURE_STORAGE_DEFAULT_BASE_URL=
AZURE_STORAGE_ASSIGNED_BASE_URL=

# SMTP Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Cricko
SMTP_FROM_EMAIL=noreply@example.com
SMTP_REPLY_TO_NAME=
SMTP_REPLY_TO_EMAIL=
DEVELOPER_EMAIL=

# Stripe Payment (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS
CORS_ORIGIN=*

# RAG Integrations
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_API_VERSION=2025-10
PINECONE_NAMESPACE_PREFIX=chatbot
PINECONE_TEXT_FIELD=text

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Local embeddings via Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

RAG_TOP_K=4
RAG_TEMPERATURE=0.2
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_MAX_CONTEXT_ITEMS=6
RAG_MAX_COMPLETION_TOKENS=1024
RAG_EMBEDDING_DIMENSION=1024
PUBLIC_CHAT_RATE_LIMIT=60
INGESTION_RATE_LIMIT=20
